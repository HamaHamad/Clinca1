{
  "expo": {
    "name": "ClinicAI",
    "slug": "clinicai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clinicai.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "ClinicAI needs access to your microphone for voice input and consultation recording.",
        "NSCameraUsageDescription": "ClinicAI needs camera access to capture lab reports and X-ray images.",
        "NSPhotoLibraryUsageDescription": "ClinicAI needs access to your photo library to upload existing medical images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.clinicai.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ClinicAI to access camera for capturing medical images"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ClinicAI to access photos for uploading lab reports"
        }
      ],
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Allow ClinicAI to use microphone for voice input"
        }
      ]
    ],
    "scheme": "clinicai",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-project-id"
      }
    }
  }
}
